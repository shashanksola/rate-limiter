# --- Server ---
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s       # Max time to read the entire request (headers + body)
SERVER_WRITE_TIMEOUT=15s      # Max time to write the response
SERVER_IDLE_TIMEOUT=60s       # Max time to wait for the next request on a keep-alive connection

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=               # Empty = no auth (fine for local dev)
REDIS_DB=0                    # Redis has 16 databases (0-15). 0 is default.

# --- JWT ---
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_EXPIRY=24h
